/* Terminal TUI design language — colour via Textual theme variables only.
   Layout is outside-in dock (textual-tui.md §5.1): status top, input+footer
   bottom, transcript fills the middle. */

Screen {
    layout: vertical;
    layers: base overlay;
}

#status-bar {
    dock: top;
    height: 1;
    background: $primary 30%;
    color: $text;
    padding: 0 1;
}

#transcript {
    height: 1fr;
    padding: 0 1;
}

#input-dock {
    dock: bottom;
    height: auto;
}

#prompt-input {
    height: 4;
    border: round $primary;
    background: $surface;
    margin: 0 1;
}

/* --- message turns: restrained header + spacing, no left gutter --- */

.turn {
    /* height:auto so a turn sizes to its content. Without this the Vertical
       subclasses inherit Textual's default height:1fr and a single turn
       stretches to fill the whole transcript. */
    height: auto;
    margin: 1 0 0 0;
}

/* Role headers carry the attribution; colour distinguishes the speaker. The
   user header is muted so the assistant's reply stays the visual focus. */
.attrib {
    color: $accent;
    text-style: bold;
}
.attrib--user {
    color: $text-muted;
}
.attrib--system {
    color: $warning;
    text-style: bold;
}

.thinking {
    color: $text-muted;
    text-style: italic;
}

/* Tool / sub-agent actions nest under a turn: indentation is the cue, no bar.
   The collapsible arrow + ⟳/✓/✗ glyph carry the state (failures auto-expand). */
ToolBlock {
    height: auto;
    margin: 1 0 0 2;
}
ToolBlock > .tool-body {
    color: $text-muted;
}

SubagentBlock {
    height: auto;
    margin: 1 0 0 2;
}

ApprovalBlock {
    height: auto;
    border: round $warning;
    padding: 0 1;
    margin: 1 0;
}
ApprovalBlock > .approval-choice {
    color: $accent;
}

/* --- transient overlay for control / observability events --- */

Toast {
    layer: overlay;
    dock: bottom;
    width: auto;
    max-width: 60%;
    height: auto;
    background: $panel;
    border: round $accent;
    padding: 0 1;
    margin: 0 2 4 0;
}
Toast.-warn {
    border: round $warning;
}
Toast.-selfmod {
    border: round $warning;
    background: $warning 20%;
}

/* --- inline command autocomplete (docked under the input, not floating) --- */

#suggestions {
    height: auto;
    max-height: 8;
    margin: 0 1;
    background: $panel;
    border: round $accent;
}
#suggestions > .option-list--option-highlighted {
    background: $accent 30%;
    color: $text;
}

/* Belt-and-suspenders: every transcript block sizes to its content. (Textual
   CSS has no `flex`; height:auto is the knob that prevents 1fr stretching.) */
AssistantText, .turn, ToolBlock, SubagentBlock {
    height: auto;
}
