Screen {
    layout: vertical;
}

#app-root {
    layout: vertical;
    height: 100%;
}

#conversation-log {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
}

#input-bar {
    height: auto;
    padding: 0 1;
    border-top: solid $accent;
}

#prompt-input {
    width: 100%;
    min-height: 3;
    max-height: 8;
}

#status-line {
    height: 1;
    padding: 0 1;
    text-style: italic dim;
    content-align: left middle;
    overflow: hidden hidden;
}

.turn,
.user-turn,
.tool-call,
.subagent {
    margin: 0 0 1 0;
}

.thinking .collapsible--title {
    color: $text-muted;
    text-style: italic;
}

.thinking-body {
    color: $text-muted;
    text-style: italic;
}

.tool-call {
    border: tall $warning;
}

.tool-call .collapsible--title {
    color: $warning;
}

.tool-call.failed {
    border: tall $error;
}

.tool-call.failed .collapsible--title {
    color: $error;
}

.tool-body {
    color: $text;
}

.subagent {
    border-left: thick cyan;
    padding-left: 1;
}

.subagent.failed {
    border-left: thick red;
}

#command-palette,
#help-screen {
    width: 70;
    height: auto;
    max-height: 80%;
    border: round $accent;
    padding: 1;
    background: $surface;
}

.theme-dark {
    background: #0f1115;
    color: #f5f7fa;
}

.theme-dark #status-line {
    background: #161b22;
    color: #9aa4b2;
}

.theme-light {
    background: #f7f7f2;
    color: #14213d;
}

.theme-light #status-line {
    background: #e9ecef;
    color: #4f5d75;
}
