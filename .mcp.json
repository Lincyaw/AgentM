{
  "mcpServers": {
    "debugmcp": {
      "type": "streamableHttp",
      "url": "http://localhost:3001/mcp",
      "timeout": 180,
      "disabled": false,
      "autoApprove": []
    },
    "vault": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "vault-mcp"
      ],
      "env": {
        "VAULT_DIR": "./vault",
        "VAULT_EMBEDDING_MODEL": "sentence-transformers/all-MiniLM-L6-v2"
      }
    }
  }
}
