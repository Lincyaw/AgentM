      12
      13 def build_parser() -> argparse.ArgumentParser:
      14     parser = argparse.ArgumentParser(description="Validate and schedule a JSON task graph")
      15     parser.add_argument("path", help="path to a JSON file containing a list of tasks")
      16     return parser
      17
      18
      19 def main(argv: list[str] | None = None) -> int:
      20     parser = build_parser()
      21     args = parser.parse_args(argv)
      22
      23     try:
      24         with Path(args.path).open("r", encoding="utf-8") as handle:
      25             data = json.load(handle)
      26         if not isinstance(data, list):
      27             raise TaskFlowError("input JSON must be a list of task objects")
      28
      29         graph = TaskGraph(data)
      30         result = {
      31             "topological_order": graph.topological_order(),
      32             "parallel_batches": graph.parallel_batches(),
      33             "owner_grouped_batches": graph.owner_grouped_batches(),
      34         }
      35         json.dump(result, sys.stdout, indent=2)
      36         sys.stdout.write("\n")
      37         return 0
      38     except (OSError, json.JSONDecodeError, TaskFlowError) as exc:
      39         parser.exit(1, f"taskflow: error: {exc}\n")
      40
      41
      42 if __name__ == "__main__":
      43     raise SystemExit(main())

