# AgentM config — place at $AGENTM_HOME/config.toml (default: ~/.agentm/config.toml)
#
# Three sections:
#   [models.*]          Model profiles (used by agentm / agentm gateway)
#   [gateway]           Gateway workspace routing
#   [feishu.bots.*]     Feishu multi-bot (used by agentm-feishu)

# ── Model profiles ───────────────────────────────────────────────────
# Select with `agentm --model doubao` or set default_model.

default_model = "doubao"

[models.doubao]
provider = "openai"
model = "doubao-seed-2-0-pro-260215"
base_url = "https://ark.cn-beijing.volces.com/api/v3"
api_key = "your-api-key-here"
context_window = 131072
reasoning_effort = "high"

[models.doubao.extra_body]
thinking = { type = "enabled" }

# ── Gateway ──────────────────────────────────────────────────────────
# Per-channel workspace isolation. Each feishu bot (identified by its
# channel_name) gets its own working directory under workspace_root.
#
# Without this section, all channels share the gateway's --cwd.

[gateway]
# $AGENTM_HOME is expanded by the gateway even when the shell env is unset.
workspace_root = "$AGENTM_HOME/workspaces"

# Optional: override the convention path for specific channels.
# [gateway.workspaces]
# researcher = "/mnt/data/rca-workspace"

# ── Feishu bots ──────────────────────────────────────────────────────
# One [feishu.bots.<name>] per Feishu app. agentm-feishu detects this
# section automatically when --app-id is not passed on the CLI.
#
# Each bot connects to the gateway as a separate peer (its own
# WireClient + FeishuAdapter). The channel_name (defaults to the bot
# key name) determines gateway routing and workspace directory.
#
# Secret precedence per bot:
#   app_secret_file > app_secret > LARK_APP_SECRET_{NAME_UPPER} env

[feishu.bots.assistant]
app_id = "cli_xxxxxxxxxxxx"
app_secret_file = "/run/secrets/feishu_assistant"  # production: file-based
channel_name = "assistant"                         # gateway routes by this
scenario = "chatbot"                               # agent behavior
# session_scope = "chat"                           # "chat" (default) or "user"
# allow_from = ["*"]                               # sender allowlist

[feishu.bots.investigator]
app_id = "cli_yyyyyyyyyyyy"
app_secret = "your-app-secret-here"                # dev convenience: inline
channel_name = "investigator"
scenario = "rca"

# ── Usage ────────────────────────────────────────────────────────────
#
# Production deployment: let the CLI write managed user units for the gateway
# and Feishu peer, with a pinned unix socket and <workspace>/.env loaded:
#   uv sync --all-packages
#   agentm gateway --cwd /path/to/workspace --install-systemd
#   loginctl enable-linger "$(whoami)"
#
# Local development only: run both processes manually with matching URLs.
# Direct ws/wss gateway binds require a token file unless you explicitly pass
# --bind-allow-anonymous:
#   mkdir -p "${AGENTM_HOME:-$HOME/.agentm}/gateway"
#   python3 - <<'PY' > "${AGENTM_HOME:-$HOME/.agentm}/gateway/token"
#   import secrets
#   print("agm_" + secrets.token_urlsafe(32))
#   PY
#   chmod 600 "${AGENTM_HOME:-$HOME/.agentm}/gateway/token"
#   agentm gateway --bind ws://127.0.0.1:8765 --bind-token-file "${AGENTM_HOME:-$HOME/.agentm}/gateway/token"
#   agentm-feishu --connect ws://127.0.0.1:8765 --token-file "${AGENTM_HOME:-$HOME/.agentm}/gateway/token" --verbose
#
# The reloadable daemon can also expose ws for remote terminal clients. It
# generates $AGENTM_HOME/gateway/token automatically when omitted:
#   agentm daemon start --bind ws://0.0.0.0:8765
#   agentm-terminal --connect ws://<host>:8765 --token "$(cat "${AGENTM_HOME:-$HOME/.agentm}/gateway/token")"
#
# Result:
#   @assistant in Feishu  -->  session in $AGENTM_HOME/workspaces/assistant/
#   @investigator         -->  session in $AGENTM_HOME/workspaces/investigator/
#
# Single-bot mode (backward compat, ignores [feishu.bots]):
#   agentm-feishu --app-id cli_xxx --app-secret /path --scenario chatbot
